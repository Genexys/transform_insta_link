{
  "name": "telegram-instagram-fix-bot",
  "version": "1.0.0",
  "description": "Telegram bot that converts Instagram links to working preview links",
  "main": "bot.js",
  "scripts": {
    "build": "tsc",
    "db:local:up": "docker compose up -d postgres",
    "db:local:down": "docker compose down",
    "db:local:reset": "docker compose down -v",
    "db:migrate": "node scripts/run-migrations.js up",
    "db:migrate:optional": "node scripts/run-migrations.js up --skip-if-no-db",
    "db:migrate:down": "node scripts/run-migrations.js down",
    "db:migrate:create": "node-pg-migrate create --migrations-dir migrations --migration-file-language sql --migration-filename-format index",
    "start": "node bot.js",
    "dev": "ts-node bot.ts",
    "railway:start": "npm run db:migrate:optional && npm start",
    "watch": "tsc -w",
    "test": "npm run build && node --test test/*.test.js"
  },
  "dependencies": {
    "@sentry/node": "^10.47.0",
    "dotenv": "^17.2.2",
    "node-pg-migrate": "^8.0.4",
    "node-telegram-bot-api": "^0.67.0",
    "pg": "^8.16.3",
    "ytdlp-nodejs": "^2.3.4"
  },
  "devDependencies": {
    "@types/node": "^20.19.13",
    "@types/node-telegram-bot-api": "^0.63.0",
    "@types/pg": "^8.16.0",
    "prettier": "^3.6.2",
    "ts-node": "^10.9.0",
    "typescript": "^5.9.2"
  },
  "keywords": [
    "telegram",
    "bot",
    "instagram",
    "fix"
  ],
  "author": "genexys",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Genexys/transform_insta_link.git"
  },
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/Genexys/transform_insta_link/issues"
  },
  "homepage": "https://github.com/Genexys/transform_insta_link#readme",
  "packageManager": "npm@11.6.2"
}
